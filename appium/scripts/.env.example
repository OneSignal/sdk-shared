# ── Recommended ───────────────────────────────────────────────────────────────
ONESIGNAL_APP_ID=your-app-id
ONESIGNAL_API_KEY=your-api-key

# ── Optional (auto-detected if not set) ──────────────────────────────────────
# FLUTTER_DIR=/path/to/OneSignal-Flutter-SDK  # default: ../../OneSignal-Flutter-SDK
# APP_PATH=/path/to/Runner.app                # default: built from FLUTTER_DIR
# BUNDLE_ID=com.onesignal.example

# ── Optional (defaults shown) ────────────────────────────────────────────────
# DEVICE=iPhone 16            # iOS default; Android default: Google Pixel 8
# OS_VERSION=18               # iOS default; Android default: 14

# iOS-only
# IOS_SIMULATOR=iPhone 16     # Simulator name (defaults to DEVICE)
# IOS_RUNTIME=iOS-18-2        # simctl runtime identifier

# Android-only
# AVD_NAME=Pixel_8            # AVD to boot

# APPIUM_PORT=4723
