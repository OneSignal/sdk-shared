{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "rootDir": ".",
    "types": [
      "@wdio/globals/types",
      "@wdio/mocha-framework"
    ]
  },
  "include": ["wdio.*.conf.ts", "tests/**/*.ts"]
}
